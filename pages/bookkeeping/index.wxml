<view class="bookkeeping-page">
  <!-- 月份切换 -->
  <view class="month-header">
    <t-icon name="chevron-left" size="48rpx" bind:tap="onPrevMonth" />
    <view class="month-text">{{currentYear}}年{{currentMonth}}月</view>
    <t-icon name="chevron-right" size="48rpx" bind:tap="onNextMonth" />
  </view>

  <!-- 月度汇总 -->
  <view class="summary-card">
    <view class="summary-item expense">
      <text class="summary-label">支出</text>
      <text class="summary-value">¥{{monthExpense}}</text>
    </view>
    <view class="summary-divider" />
    <view class="summary-item income">
      <text class="summary-label">收入</text>
      <text class="summary-value">¥{{monthIncome}}</text>
    </view>
    <view class="summary-divider" />
    <view class="summary-item balance">
      <text class="summary-label">结余</text>
      <text class="summary-value">¥{{monthBalance}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <t-icon name="loading" size="48rpx" color="#999" />
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 记录列表 -->
  <view class="record-list" wx:if="{{!loading && records.length > 0}}">
    <view class="record-item" wx:for="{{records}}" wx:key="_id">
      <t-swipe-cell right="{{swipeRight}}" data-id="{{item._id}}" bind:click="onSwipeActionClick">
        <view class="record-content" data-id="{{item._id}}" bind:tap="onRecordTap">
          <view class="record-left">
            <view class="record-category {{item.type}}">{{item.category}}</view>
            <view class="record-note" wx:if="{{item.note}}">{{item.note}}</view>
          </view>
          <view class="record-right">
            <text class="record-amount {{item.type}}">
              {{item.type === 'expense' ? '-' : '+'}}¥{{item.amountText}}
            </text>
            <text class="record-date">{{item.date}}</text>
          </view>
        </view>
      </t-swipe-cell>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <t-empty t-class="empty-cls" image="https://tdesign.gtimg.com/mobile/demos/empty1.png" description="暂无记录，点击下方按钮开始记账" />
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn-wrap">
    <t-button theme="primary" size="large" block bind:tap="openAddPopup">
      <t-icon name="add" size="40rpx" />
    </t-button>
  </view>

  <!-- 添加/编辑记录弹窗 -->
  <add-record-popup visible="{{showAddPopup}}" editRecord="{{editRecord}}" bind:close="closeAddPopup" bind:success="onAddSuccess" />

  <!-- 删除确认弹窗 -->
  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="确定要删除这条记录吗？"
    confirm-btn="{{confirmBtn}}"
    cancel-btn="{{cancelBtn}}"
    bind:confirm="onConfirmDelete"
    bind:cancel="onCancelDelete"
  />

  <t-toast id="t-toast" />
</view>
