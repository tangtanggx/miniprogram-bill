page {
  background: #f5f6f8;
  height: 100vh;
  overflow: hidden;
}

.bookkeeping-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  box-sizing: border-box;
  overflow-y: auto;
}

/* 月份切换 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0 24rpx;
  gap: 24rpx;
}

.month-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  min-width: 240rpx;
  text-align: center;
}

/* 月度汇总 */
.summary-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 600;
}

.summary-item.expense .summary-value {
  color: #e34d59;
}

.summary-item.income .summary-value {
  color: #00a870;
}

.summary-item.balance .summary-value {
  color: #333;
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 记录列表 */
.record-list {
  margin-top: 8rpx;
}

.record-item {
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

.record-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.record-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.record-category {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.record-category.expense {
  background: #fff0f0;
  color: #e34d59;
}

.record-category.income {
  background: #e8f8f0;
  color: #00a870;
}

.record-note {
  font-size: 24rpx;
  color: #999;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.record-amount {
  font-size: 34rpx;
  font-weight: 600;
}

.record-amount.expense {
  color: #e34d59;
}

.record-amount.income {
  color: #00a870;
}

.record-date {
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn-wrap {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  z-index: 100;
}

/* swipe cell 样式补丁 */
.t-swipe-cell {
  border-radius: 16rpx;
  overflow: hidden;
}

.swipe-delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
  font-size: 28rpx;
  white-space: nowrap;
}
