/* 添加弹窗 */
.add-popup {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

.add-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.type-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.type-tab {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  transition: all 0.2s;
}

.type-tab.active {
  background: #0052d9;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 500;
}

/* 金额输入 */
.amount-input-wrap {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.amount-prefix {
  font-size: 56rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.amount-input {
  font-size: 56rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

/* 分类选择 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: calc(20% - 13rpx);
  padding: 16rpx 0;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.category-item.selected {
  background: #e8f0fe;
  border-color: #0052d9;
}

.category-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-item.selected .category-icon-wrap {
  background: #d4e3fc;
}

.category-label {
  font-size: 22rpx;
  color: #666;
}

.category-item.selected .category-label {
  color: #0052d9;
  font-weight: 500;
}

/* 日期时间 */
.datetime-wrap {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.datetime-wrap picker {
  flex: 1;
}

.datetime-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.datetime-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 备注 */
.note-input-wrap {
  margin-bottom: 32rpx;
}
